# Sovereign Node 9010 v3.9.1 — Example environment for docker-compose
# Copy to .env and fill in real secrets before running in production.

# REQUIRED — Tau Refusal Gate token (must be sent as X-TAAS-AUTH header)
TAAS_AUTH_TOKEN=replace-with-a-long-random-secret-at-least-32-chars

# REQUIRED — Used for HMAC-SHA256 Merkle seals on facts and affidavits
AUDIT_SECRET_KEY=another-long-random-secret-for-cryptographic-audit-trail

# Optional overrides
# SOVEREIGN_DB_PATH=/app/data/vault/facts_registry.db
# PORT=8000
