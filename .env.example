# Sovereign Node 9010 — Environment Variables
# Copy to .env and fill in values before deployment

# Server
PORT=8000

# Logging (pino log level: trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# SQLite Persistence (Azure Files mount path in production)
DB_PATH=/app/data/database.sqlite

# Tracing — Request Correlation
# Every request receives an X-Trace-Id header. Callers may also supply one
# (e.g. from an Azure API Management policy or Application Gateway) so that
# the same trace ID flows end-to-end through logs.
# No external export by default; add OTLP_ENDPOINT to ship spans to
# Azure Application Insights or any OpenTelemetry-compatible collector.
# OTLP_ENDPOINT=https://your-collector:4318/v1/traces

# Azure Key Vault secrets (injected via App Service / Container Apps config)
# AUDIT_SECRET=@Microsoft.KeyVault(VaultName=YOUR_VAULT;SecretName=AuditSecret)
# GEMINI_API_KEY=@Microsoft.KeyVault(VaultName=YOUR_VAULT;SecretName=GeminiApiKey)
